# Nostr Daily Bot - Environment Variables
# Copy this file to .env and fill in your values

# Private key for signing Nostr events (nsec or hex format)
# This overrides any key specified in config.toml
NOSTR_PRIVATE_KEY=nsec1...

# Log level (error, warn, info, debug, trace)
# Can also use module-specific: warn,nostr_daily_bot=debug
RUST_LOG=info

# Log format: "pretty" for development, "json" for production
LOG_FORMAT=pretty

# ─────────────────────────────────────────────────────────────────────────────
# BTCPay Server Integration (optional - enables tipping)
# ─────────────────────────────────────────────────────────────────────────────

# BTCPay Server URL (e.g., https://mainnet.demo.btcpayserver.org)
# BTCPAY_BASE_URL=https://mainnet.demo.btcpayserver.org

# API key with invoice permissions (create in BTCPay: Account > API Keys)
# BTCPAY_API_KEY=your-api-key

# Store ID (find in BTCPay: Store Settings > General > Store ID)
# BTCPAY_STORE_ID=your-store-id

# Webhook secret for verifying incoming webhooks (create in BTCPay: Store > Webhooks)
# BTCPAY_WEBHOOK_SECRET=your-webhook-secret

# Default tip amount in satoshis (optional, default: 5000)
# BTCPAY_DEFAULT_TIP_SATS=5000

# Admin token for accessing payment history (generate a secure random string)
# ADMIN_TOKEN=your-secure-admin-token
